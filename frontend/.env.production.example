VITE_APP_NAME=HR Shakya ERP
# Same origin as the SPA when served behind a reverse proxy, or full API URL for cross-origin.
VITE_API_BASE_URL=https://api.your-production-domain.com
VITE_API_PREFIX=/api/v1
# Must match backend AUTH_USE_HTTP_ONLY_COOKIES=true
VITE_AUTH_USE_HTTP_ONLY_COOKIES=true
# Enable client auth diagnostics in production (no secrets logged). Dev enables automatically.
# VITE_AUTH_DEBUG=true
