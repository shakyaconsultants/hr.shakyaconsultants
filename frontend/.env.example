VITE_APP_NAME=HR Shakya ERP
# Use empty string in dev to route API calls through the Vite proxy (same-origin, required for HttpOnly cookie testing).
VITE_API_BASE_URL=
VITE_API_PREFIX=/api/v1
VITE_API_PROXY_TARGET=http://localhost:4000
# Must match backend AUTH_USE_HTTP_ONLY_COOKIES (false for localStorage dev, true for production-style testing)
VITE_AUTH_USE_HTTP_ONLY_COOKIES=false
