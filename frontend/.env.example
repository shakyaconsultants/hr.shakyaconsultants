# Frontend — copy to frontend/.env (local) or set in hosting dashboard.
# Production uses the same keys; only values change.

VITE_APP_NAME=HR Shakya ERP
# Local dev: leave empty to use Vite proxy. Production: full API URL or same-origin path.
VITE_API_BASE_URL=
VITE_API_PREFIX=/api/v1
VITE_API_PROXY_TARGET=http://localhost:4000
# Match backend AUTH_USE_HTTP_ONLY_COOKIES (false local, true production)
VITE_AUTH_USE_HTTP_ONLY_COOKIES=false
# Real-time chat (optional — set SOCKET_ENABLED=true on backend too)
# VITE_SOCKET_ENABLED=true
# VITE_SOCKET_URL=https://your-api.onrender.com
# VITE_SOCKET_PATH=/socket.io
# Production: set to your Render API URL, e.g. https://hr-shakya-api.onrender.com
# FRONTEND_URL on the backend must exactly match this site's origin.
