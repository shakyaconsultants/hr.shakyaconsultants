# Production overrides — use with Docker or production deploy
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
SWAGGER_ENABLED=false

FRONTEND_URL=https://your-production-domain.com,https://www.your-production-domain.com

MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/hr_shakya
MONGODB_DB_NAME=hr_shakya

# Upstash Redis (required in production — use official rediss:// URL)
REDIS_URL=rediss://your-upstash-endpoint.upstash.io:6379
REDIS_TOKEN=your-upstash-token

JWT_ACCESS_SECRET=replace-with-strong-production-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-strong-production-secret-min-32-chars
FIELD_ENCRYPTION_KEY=replace-with-strong-field-encryption-key-min-32-chars

AUTH_USE_HTTP_ONLY_COOKIES=true
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=strict

AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

CORS_CREDENTIALS=true
