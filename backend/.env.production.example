# =============================================================================
# Production environment — copy every variable to Render (or your host) Dashboard
# Environment → Add Environment Variable
# Generate secrets: openssl rand -base64 32
# =============================================================================

NODE_ENV=production
APP_NAME=HR Shakya ERP
APP_VERSION=1.0.0
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1

# Comma-separated allowed frontend origins (your deployed SPA URL)
FRONTEND_URL=https://your-production-domain.com
CORS_CREDENTIALS=true

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/hr_shakya
MONGODB_DB_NAME=hr_shakya

# Redis (required in production) — single URL with embedded credentials
REDIS_URL=rediss://default:YOUR_TOKEN@your-endpoint.upstash.io:6379

QUEUE_PREFIX=hr-shakya
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=5000

# Secrets — each must be at least 32 characters, unique per environment
JWT_ACCESS_SECRET=replace-with-strong-production-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-strong-production-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=hr-shakya
JWT_AUDIENCE=hr-shakya-api

# Required — encrypts sensitive settings fields (separate from JWT secrets)
FIELD_ENCRYPTION_KEY=replace-with-strong-field-encryption-key-min-32-chars

# Auth cookies (required true in production)
AUTH_USE_HTTP_ONLY_COOKIES=true
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=strict
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER_PREFIX=hr-shakya

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=HR Shakya ERP
SMTP_FROM_EMAIL=noreply@example.com

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
REQUEST_BODY_LIMIT=10mb

LOG_LEVEL=info
LOG_DIR=/tmp/logs

SWAGGER_ENABLED=false
SWAGGER_PATH=/api-docs

UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

SOCKET_ENABLED=true
SOCKET_PATH=/socket.io
