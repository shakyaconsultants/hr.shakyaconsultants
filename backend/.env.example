# =============================================================================
# HR Shakya Backend — single environment template
# Copy to backend/.env for local dev. On Render/hosting, set the same keys in
# the dashboard (NODE_ENV=production). Do not maintain a separate .env.production file.
# Generate secrets: openssl rand -base64 32
# =============================================================================

# --- Core (required) ---
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173

# --- Database (required) ---
MONGODB_URI=mongodb://localhost:27017/hr_shakya
MONGODB_DB_NAME=hr_shakya

# --- Security (required — min 32 chars each) ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
FIELD_ENCRYPTION_KEY=change-me-field-encryption-key-min-32-chars

# --- Redis (required in production; optional locally) ---
REDIS_URL=

# --- Auth cookies (production: all true / none) ---
AUTH_USE_HTTP_ONLY_COOKIES=false
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# --- Email (required for welcome/reset emails) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=HR Shakya ERP
SMTP_FROM_EMAIL=noreply@example.com

# --- Media uploads ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Local seed only (npm run seed:init — not needed on Render runtime) ---
SEED_COMPANY_CODE=HRS
SUPER_ADMIN_EMAIL=superadmin@hrshakya.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# --- Optional defaults (safe to omit; schema provides defaults) ---
# APP_NAME=HR Shakya ERP
# LOG_LEVEL=debug
# SWAGGER_ENABLED=true
# SOCKET_ENABLED=true
