# Application
NODE_ENV=development
APP_NAME=HR Shakya ERP
APP_VERSION=1.0.0
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1

# CORS / Frontend
FRONTEND_URL=http://localhost:5173,http://localhost:5174
CORS_CREDENTIALS=true

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hr_shakya
MONGODB_DB_NAME=hr_shakya

# Redis (optional — leave empty to run without cache/BullMQ)
# Use a single URL with embedded credentials (Upstash example):
# REDIS_URL=rediss://default:YOUR_TOKEN@your-endpoint.upstash.io:6379
REDIS_URL=

# BullMQ
QUEUE_PREFIX=hr-shakya
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=5000

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=hr-shakya
JWT_AUDIENCE=hr-shakya-api

# Field encryption (32+ chars — independent from JWT rotation)
FIELD_ENCRYPTION_KEY=change-me-field-encryption-key-min-32-chars

# Auth
BCRYPT_ROUNDS=12
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MS=900000
AUTH_REMEMBER_ME_DAYS=30
AUTH_USE_HTTP_ONLY_COOKIES=false
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_PERMISSION_CACHE_TTL_SECONDS=900

# Local init seed (npm run seed:init — gitignored seed.local.ts, copy from seed.local.example.ts)
SEED_COMPANY_NAME=HR Shakya
SEED_COMPANY_LEGAL_NAME=HR Shakya Private Limited
SEED_COMPANY_CODE=HRS
SEED_COMPANY_EMAIL=admin@hrshakya.com
SEED_COMPANY_PHONE=+919999999999
SEED_COMPANY_ADDRESS_LINE1=123 Main Street
SEED_COMPANY_CITY=Mumbai
SEED_COMPANY_STATE=Maharashtra
SEED_COMPANY_COUNTRY=India
SEED_COMPANY_POSTAL_CODE=400001
SEED_COMPANY_TIMEZONE=Asia/Kolkata
SEED_COMPANY_CURRENCY=INR
SEED_COMPANY_FISCAL_YEAR_START=04-01
SEED_ADMIN_FIRST_NAME=Super
SEED_ADMIN_LAST_NAME=Admin
SEED_ADMIN_EMAIL=superadmin@hrshakya.com
SEED_ADMIN_PASSWORD=SuperAdmin@123

# Super Admin credentials (used by seed.local.ts — never commit seed.local.ts)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@hrshakya.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123
SUPER_ADMIN_PHONE=
SECURE_TOKEN_EXPIRY_HOURS=48

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER_PREFIX=hr-shakya

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=HR Shakya ERP
SMTP_FROM_EMAIL=noreply@example.com

# Security / Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
REQUEST_BODY_LIMIT=10mb

# Logging
LOG_LEVEL=debug
LOG_DIR=logs

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs

# Upload
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Socket.io
SOCKET_ENABLED=true
SOCKET_PATH=/socket.io
